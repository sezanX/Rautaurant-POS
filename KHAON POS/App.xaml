<Application x:Class="RestaurantPOS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#66BD76" SecondaryColor="#66BD76" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EAF9ED" />
            <SolidColorBrush x:Key="PrimaryGreenBrush" Color="#66BD76" />
            <SolidColorBrush x:Key="TextDarkBrush" Color="#212121" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#757575" />
            <SolidColorBrush x:Key="BorderGreyBrush" Color="#E0E0E0" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
