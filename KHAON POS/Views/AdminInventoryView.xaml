<UserControl x:Class="KHAONPOS.Views.AdminInventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:KHAONPOS.Converters">
    <UserControl.Resources>
        <converters:ImageConverter x:Key="ImageConverter" />
    </UserControl.Resources>
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Menu Items Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,24" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="450" />
            </Grid.ColumnDefinitions>

            <!-- Inventory List -->
            <materialDesign:Card Grid.Column="0" Padding="16" UniformCornerRadius="8" Background="White" Margin="0,0,24,0" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="ViewList" Width="24" Height="24" Foreground="{DynamicResource PrimaryGreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Menu Items" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#212121"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding MenuItems}" SelectedItem="{Binding SelectedItem}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Background="White" RowBackground="White" AlternatingRowBackground="White"
                              GridLinesVisibility="None"
                              materialDesign:DataGridAssist.CellPadding="16" materialDesign:DataGridAssist.ColumnHeaderPadding="16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" />
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:C}}" />
                            <DataGridTextColumn Header="Prep Time" Binding="{Binding PreparationTimeMinutes, StringFormat={}{0} min}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <!-- Add / Edit Item Form -->
            <materialDesign:Card Grid.Column="1" Padding="20" UniformCornerRadius="8" Background="White" VerticalAlignment="Top" TextElement.Foreground="#212121" materialDesign:ElevationAssist.Elevation="Dp2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0">
                    <StackPanel>
                        <TextBlock Text="Manage Item" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" Foreground="#212121" />
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:HintAssist.Hint="Name" Foreground="#212121"
                                     Background="#F7F9F8" BorderBrush="#E0E0E0"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,10,10" />
                                     
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedValue="{Binding NewCategoryId}" 
                                      DisplayMemberPath="Name" SelectedValuePath="Id" Foreground="#212121"
                                      Background="#F7F9F8" BorderBrush="#E0E0E0"
                                      materialDesign:HintAssist.Hint="Category" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,10" />
                                      
                            <TextBox Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:HintAssist.Hint="Description" Foreground="#212121"
                                     Background="#F7F9F8" BorderBrush="#E0E0E0"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,10" />
                                     
                            <TextBox Grid.Row="2" Text="{Binding NewPrice, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:HintAssist.Hint="Price" Foreground="#212121"
                                     Background="#F7F9F8" BorderBrush="#E0E0E0"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,10,0" />
                                     
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewPrepTime, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:HintAssist.Hint="Prep Time (Minutes)" Foreground="#212121"
                                     Background="#F7F9F8" BorderBrush="#E0E0E0"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,0" />
                        </Grid>
                        
                        <TextBlock Text="Product Image (Square 1:1)" Foreground="#757575" Margin="0,16,0,6"/>
                        <Border x:Name="ImageBorder" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Width="180" Height="180" HorizontalAlignment="Left" Margin="0,0,0,14" ClipToBounds="True" Background="White">
                            <Grid>
                                <!-- Image Preview -->
                                <Image Source="{Binding NewDisplayImage, Converter={StaticResource ImageConverter}}" Stretch="UniformToFill" />
                                
                                <!-- No Image placeholder -->
                                <TextBlock Text="No Image" Foreground="#9E9E9E" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NewDisplayImage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <!-- Hover Upload Overlay -->
                                <Border Background="#80000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=ImageBorder}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <Button Command="{Binding UploadPhotoCommand}" 
                                            Style="{StaticResource MaterialDesignFlatButton}" 
                                            Foreground="White" 
                                            HorizontalAlignment="Center" 
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Camera" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="Upload" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="Save Item" Command="{Binding SaveItemCommand}" Background="{DynamicResource PrimaryGreenBrush}" BorderBrush="{DynamicResource PrimaryGreenBrush}" Foreground="White" Margin="0,0,10,0" Width="120" />
                            <Button Content="Delete Item" Command="{Binding DeleteItemCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#E53935" BorderBrush="#E53935" Margin="0,0,10,0" />
                            <Button Content="Clear" Command="{Binding ClearFormCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#757575" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
