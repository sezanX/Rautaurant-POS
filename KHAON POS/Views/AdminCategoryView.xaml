<UserControl x:Class="KHAONPOS.Views.AdminCategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Category Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,24" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="450" />
            </Grid.ColumnDefinitions>

            <!-- Categories List Card -->
            <materialDesign:Card Grid.Column="0" Padding="16" UniformCornerRadius="8" Background="White" Margin="0,0,24,0" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Shape" Width="24" Height="24" Foreground="{DynamicResource PrimaryGreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Categories List" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#212121"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Background="White" RowBackground="White" AlternatingRowBackground="White"
                              GridLinesVisibility="None"
                              materialDesign:DataGridAssist.CellPadding="16" materialDesign:DataGridAssist.ColumnHeaderPadding="16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" />
                            <DataGridTemplateColumn Header="Icon" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon Kind="{Binding IconName}" Width="22" Height="22" Foreground="{DynamicResource PrimaryGreenBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Category Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Icon Name" Binding="{Binding IconName}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <!-- Manage Category Form Card -->
            <materialDesign:Card Grid.Column="1" Padding="20" UniformCornerRadius="8" Background="White" VerticalAlignment="Top" TextElement.Foreground="#212121" materialDesign:ElevationAssist.Elevation="Dp2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0">
                    <StackPanel>
                        <TextBlock Text="Manage Category" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" Foreground="#212121" />
                        
                        <TextBox Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}" 
                                 materialDesign:HintAssist.Hint="Category Name" Foreground="#212121"
                                 Background="#F7F9F8" BorderBrush="#E0E0E0"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,14" />
                                 
                        <ComboBox ItemsSource="{Binding AvailableIcons}" SelectedItem="{Binding CategoryIconName}"
                                  IsEditable="True"
                                  Text="{Binding CategoryIconName, UpdateSourceTrigger=PropertyChanged}"
                                  materialDesign:HintAssist.Hint="Icon Name (e.g. Hamburger, Pizza, CupWater)" Foreground="#212121"
                                  Background="#F7F9F8" BorderBrush="#E0E0E0"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,14" />

                        <!-- Icon Preview -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Icon Preview:" Foreground="#757575" VerticalAlignment="Center"/>
                            <materialDesign:PackIcon Kind="{Binding CategoryIconName}" Width="28" Height="28" Foreground="{DynamicResource PrimaryGreenBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding CategoryErrorMessage}" Foreground="#E53935" FontWeight="SemiBold" Margin="0,0,0,12" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <Button Content="Save Category" Command="{Binding SaveCategoryCommand}" Background="{DynamicResource PrimaryGreenBrush}" BorderBrush="{DynamicResource PrimaryGreenBrush}" Foreground="White" Margin="0,0,10,0" Width="130" />
                            <Button Content="Delete" Command="{Binding DeleteCategoryCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#E53935" BorderBrush="#E53935" Margin="0,0,10,0" />
                            <Button Content="Clear" Command="{Binding ClearFormCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#757575" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
