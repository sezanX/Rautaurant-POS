<UserControl x:Class="KHAONPOS.Views.AdminAnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Advanced Analytics" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,24" />

        <materialDesign:Card Grid.Row="1" Padding="24" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="ChartPie" Width="24" Height="24" Foreground="{DynamicResource PrimaryGreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Sales by Category" FontSize="20" FontWeight="Bold" Foreground="#212121" VerticalAlignment="Center"/>
                </StackPanel>

                <lvc:PieChart Grid.Row="1" Series="{Binding CategorySalesSeries}" LegendPosition="Right" MinHeight="300"/>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
