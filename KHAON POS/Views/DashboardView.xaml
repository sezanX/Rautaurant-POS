<UserControl x:Class="RestaurantPOS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:converters="clr-namespace:RestaurantPOS.Converters"
             xmlns:viewmodels="clr-namespace:RestaurantPOS.ViewModels"
             xmlns:views="clr-namespace:RestaurantPOS.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:CurrencyConverter x:Key="CurrencyConverter" />
        <converters:ActiveTabConverter x:Key="ActiveTabConverter" />
        
        <Style x:Key="NavTabStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="NavTabs" />
            <Setter Property="Foreground" Value="#757575" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <Border x:Name="ActiveBorder" BorderThickness="4,0,0,0" BorderBrush="Transparent" Padding="12,0,16,0">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#66BD76" />
                                <Setter Property="Background" Value="#E8F5E9" />
                                <Setter TargetName="ActiveBorder" Property="BorderBrush" Value="#66BD76" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#E8F5E9" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate DataType="{x:Type viewmodels:AdminOverviewViewModel}">
            <views:AdminOverviewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AdminAnalyticsViewModel}">
            <views:AdminAnalyticsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AdminReportsViewModel}">
            <views:AdminReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AdminUsersViewModel}">
            <views:AdminUsersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AdminInventoryViewModel}">
            <views:AdminInventoryView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Profile -->
                <StackPanel Grid.Row="0" Margin="24,32,24,32">
                    <!-- Placeholder avatar -->
                    <Border Width="64" Height="64" CornerRadius="32" Background="#E8F5E9" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="A" Foreground="#66BD76" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Welcome," Foreground="#757575" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="Admin" Foreground="#212121" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="16,0">
                    <RadioButton Style="{StaticResource NavTabStyle}" Command="{Binding NavigateAdminCommand}" CommandParameter="Overview" 
                                 IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource ActiveTabConverter}, ConverterParameter=Overview}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton Style="{StaticResource NavTabStyle}" Command="{Binding NavigateAdminCommand}" CommandParameter="Analytics" 
                                 IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource ActiveTabConverter}, ConverterParameter=Analytics}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartLine" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Analytics" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton Style="{StaticResource NavTabStyle}" Command="{Binding NavigateAdminCommand}" CommandParameter="Reports" 
                                 IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource ActiveTabConverter}, ConverterParameter=Reports}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocumentOutline" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reports" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton Style="{StaticResource NavTabStyle}" Command="{Binding NavigateAdminCommand}" CommandParameter="Users" 
                                 IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource ActiveTabConverter}, ConverterParameter=Users}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Users" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton Style="{StaticResource NavTabStyle}" Command="{Binding NavigateAdminCommand}" CommandParameter="Inventory" 
                                 IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource ActiveTabConverter}, ConverterParameter=Inventory}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewList" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Inventory" VerticalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>


            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1" Margin="32" Content="{Binding CurrentAdminViewModel}" />
    </Grid>
</UserControl>
