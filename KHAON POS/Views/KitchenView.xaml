<UserControl x:Class="RestaurantPOS.Views.KitchenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:RestaurantPOS.Converters">
    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    </UserControl.Resources>
    
    <Grid Margin="32" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Active Tickets" FontSize="28" FontWeight="Bold" Foreground="#66BD76" />
            <Button Command="{Binding RefreshCommand}" HorizontalAlignment="Right" Background="#E0E0E0" BorderBrush="Transparent" Foreground="#424242" Height="40" materialDesign:ButtonAssist.CornerRadius="20">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="#66BD76" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ActiveOrders.Count, StringFormat=Queue : {0}}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Kanban Board style list of active orders -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ActiveOrders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="300" Margin="0,0,24,24" Background="White" CornerRadius="8" BorderThickness="0,6,0,0" BorderBrush="#66BD76">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#E0E0E0" Opacity="0.5"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Padding="24,24,24,16" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Left">
                                            <TextBlock Text="ORDER" FontSize="11" FontWeight="Bold" Foreground="#9E9E9E"/>
                                            <TextBlock Text="{Binding Order.Id, StringFormat=#{0}}" FontWeight="Bold" FontSize="24" Foreground="#212121" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        
                                        <Border Background="#E8F5E9" CornerRadius="16" Padding="12,6" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ClockOutline" Foreground="#66BD76" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding TimeRemaining}" FontWeight="Bold" FontSize="18" Foreground="#66BD76" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Items List -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Order.OrderItems}" Margin="24,16,24,16">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Quantity}" FontWeight="Bold" FontSize="20" Foreground="#66BD76" Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding MenuItem.Name}" FontWeight="Bold" FontSize="18" Foreground="#212121" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MenuItem.Category}" FontSize="13" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                                                </Grid>
                                                <!-- Remarks -->
                                                <TextBlock Text="{Binding Remarks}" Foreground="#757575" FontSize="14" Margin="26,4,0,0" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Remarks}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Remarks}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="#EEEEEE" Margin="24,0"/>

                                <!-- Footer Buttons -->
                                <Grid Grid.Row="2" Margin="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            Foreground="#66BD76" BorderBrush="#66BD76" Height="44" materialDesign:ButtonAssist.CornerRadius="8"
                                            Command="{Binding DataContext.AddTimeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ClockPlusOutline" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="+5 Min" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                            
                                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignRaisedButton}" 
                                            Background="#66BD76" BorderBrush="#66BD76" Foreground="White" Height="44" materialDesign:ButtonAssist.CornerRadius="8"
                                            Command="{Binding DataContext.MarkAsPreparedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckCircleOutline" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Done" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
