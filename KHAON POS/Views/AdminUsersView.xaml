<UserControl x:Class="RestaurantPOS.Views.AdminUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="User Management" FontSize="28" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,24" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- Users List -->
            <materialDesign:Card Grid.Column="0" Padding="16" UniformCornerRadius="8" Background="White" Margin="0,0,24,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24" Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="System Users" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#212121"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              materialDesign:DataGridAssist.CellPadding="16" materialDesign:DataGridAssist.ColumnHeaderPadding="16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" />
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <!-- Add User / Edit Role -->
            <materialDesign:Card Grid.Column="1" Padding="24" UniformCornerRadius="8" Background="White" VerticalAlignment="Top" TextElement.Foreground="#212121">
                <StackPanel>
                    <TextBlock Text="Add New User" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#212121"/>
                    
                    <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Username" 
                             Foreground="#212121"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16" />
                             
                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Password" 
                             Foreground="#212121"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16" />
                             
                    <ComboBox ItemsSource="{Binding AvailableRoles}" SelectedItem="{Binding NewRole}"
                              Foreground="#212121"
                              materialDesign:HintAssist.Hint="Role" Margin="0,0,0,24" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                              
                    <Button Content="Add User" Command="{Binding AddUserCommand}" Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White" Margin="0,0,0,32" />
                    
                    <Separator Margin="0,0,0,32" Background="#E0E0E0"/>
                    
                    <TextBlock Text="Manage Selected User" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#212121" />
                    <TextBlock Text="Select a user from the table to delete them from the system." Foreground="#757575" TextWrapping="Wrap" Margin="0,0,0,16" />
                    <Button Content="Delete Selected User" Command="{Binding DeleteUserCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#F44336" BorderBrush="#F44336" />
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
