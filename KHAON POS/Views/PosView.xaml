<UserControl x:Class="RestaurantPOS.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:RestaurantPOS.Converters">
    
    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <!-- Left / Center Panel: Categories and Items -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Categories" FontSize="18" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,16" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Using RadioButton styled as pill -->
                                <RadioButton Content="{Binding Name}" GroupName="Categories" 
                                             Style="{StaticResource MaterialDesignTabRadioButton}" 
                                             Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                             CommandParameter="{Binding}"
                                             Margin="0,0,12,0" Padding="24,8" FontSize="14" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="Items" FontSize="18" FontWeight="SemiBold" Foreground="#424242" Margin="0,32,0,16" />
            </StackPanel>

            <!-- Menu Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Width="220" Height="280" Margin="0,0,24,24" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2" Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="140"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Image and Badges -->
                                    <Border CornerRadius="8,8,0,0" Background="#EEEEEE" ClipToBounds="True">
                                        <Grid>
                                            <!-- Assuming we have URLs, but for dummy just show an icon if it fails -->
                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill" />
                                            
                                            <!-- Price Badge -->
                                            <Border Background="White" CornerRadius="16" Padding="12,4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                                                <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" FontWeight="Bold" Foreground="#212121" FontSize="13"/>
                                            </Border>
                                            
                                            <!-- Prep Time Badge -->
                                            <Border Background="White" CornerRadius="16" Padding="12,4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding PreparationTimeMinutes}" FontWeight="Bold" Foreground="#66BD76" FontSize="12"/>
                                                    <TextBlock Text="min" FontWeight="Bold" Foreground="#66BD76" FontSize="12" Margin="2,0,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Details -->
                                    <Grid Grid.Row="1" Margin="16">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#212121" TextWrapping="Wrap" MaxHeight="44"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#757575" TextWrapping="Wrap" Margin="0,4,0,0" MaxHeight="34"/>
                                        </StackPanel>
                                        
                                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                                                Background="#66BD76" BorderBrush="#66BD76" 
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="Plus" Foreground="White" Width="24" Height="24" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Right Panel: Cart -->
        <Border Grid.Column="1" Background="White" BorderThickness="1,0,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Order Header -->
                <Grid Grid.Row="0" Margin="24">
                    <TextBlock Text="{Binding CurrentOrder.Id, StringFormat=Order #{0}}" FontSize="24" FontWeight="Bold" Foreground="#212121" VerticalAlignment="Center" />
                    <Button Content="Clear All" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#E53935" HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding ClearAllCommand}"/>
                </Grid>
                
                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#EEEEEE"/>
                
                <!-- Cart Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,0">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,16,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border CornerRadius="8" Background="#EEEEEE" ClipToBounds="True" Height="60">
                                        <Image Source="{Binding MenuItem.ImagePath}" Stretch="UniformToFill" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding MenuItem.Name}" FontWeight="Bold" Foreground="#212121" FontSize="14" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Button Grid.Column="0" Content="-" Style="{StaticResource MaterialDesignOutlinedButton}" Width="32" Height="32" Padding="0"
                                                    Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Quantity}" VerticalAlignment="Center" Margin="16,0" FontWeight="Bold"/>
                                            <Button Grid.Column="2" Content="+" Style="{StaticResource MaterialDesignOutlinedButton}" Width="32" Height="32" Padding="0"
                                                    Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Grid>
                                        
                                        <!-- Remark and Extra Charge Input -->
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBox Grid.Column="0" Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                                     materialDesign:HintAssist.Hint="Add Remark" 
                                                     Background="#F5F5F5" BorderThickness="0" Padding="8,4" FontSize="12" Margin="0,0,4,0">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" /> 
                                                </TextBox.InputBindings>
                                            </TextBox>
                                            
                                            <TextBox Grid.Column="1" Text="{Binding ExtraCharge, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                                     materialDesign:HintAssist.Hint="Extra ($)" 
                                                     Background="#F5F5F5" BorderThickness="0" Padding="8,4" FontSize="12" Margin="0,0,4,0">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding DataContext.UpdateExtraChargeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" /> 
                                                </TextBox.InputBindings>
                                            </TextBox>
                                            
                                            <Button Grid.Column="2" Content="Add" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#66BD76" Padding="4" Height="24"
                                                    Command="{Binding DataContext.UpdateExtraChargeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                        </Grid>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat={}{0:C}}" FontWeight="Bold" Foreground="#212121" VerticalAlignment="Top"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Totals and Checkout -->
                <Border Grid.Row="2" Background="#F1F8E9" Padding="24">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Subtotal" Foreground="#616161" FontSize="14"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C}}" FontWeight="SemiBold" Foreground="#424242" HorizontalAlignment="Right" FontSize="14"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Estimated Time" Foreground="#616161" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding EstimatedTime}" FontWeight="SemiBold" Foreground="#424242" FontSize="14"/>
                            <TextBlock Text=" min" FontWeight="SemiBold" Foreground="#424242" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="Total" Foreground="#212121" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C}}" Foreground="#212121" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <Button Content="Print" Style="{StaticResource MaterialDesignOutlinedButton}" Height="48" Margin="0,0,0,16" Foreground="#66BD76" BorderBrush="#66BD76" Command="{Binding PrintReceiptCommand}"/>
                    <Button Content="Place Order" Style="{StaticResource MaterialDesignRaisedButton}" Height="48" Background="#66BD76" BorderBrush="#66BD76" FontSize="16" FontWeight="Bold" Command="{Binding CheckoutCommand}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashRegister" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Place Order" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
