<UserControl x:Class="RestaurantPOS.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:RestaurantPOS.ViewModels"
             xmlns:local="clr-namespace:RestaurantPOS.Views">
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding LoginCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <local:RoleSelectedBrushConverter x:Key="RoleSelectedBrushConverter" />
        <local:RoleSelectedBackgroundConverter x:Key="RoleSelectedBackgroundConverter" />
        <local:RoleSelectedThicknessConverter x:Key="RoleSelectedThicknessConverter" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="40,28,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,24,0" CornerRadius="28">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F3FFF7" Offset="0" />
                        <GradientStop Color="#E6F7E9" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="36">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Welcome back" FontSize="34" FontWeight="Bold" Foreground="#1B5E20" />
                        <TextBlock Text="Choose a role and sign in to manage the restaurant with confidence."
                                   TextWrapping="Wrap" FontSize="16" Foreground="#5F6B63" Margin="0,10,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,24,0,0">
                        <Border Padding="20" CornerRadius="12" Background="{Binding SelectedRole, Converter={StaticResource RoleSelectedBackgroundConverter}, ConverterParameter=Admin}" BorderBrush="{Binding SelectedRole, Converter={StaticResource RoleSelectedBrushConverter}, ConverterParameter=Admin}" BorderThickness="{Binding SelectedRole, Converter={StaticResource RoleSelectedThicknessConverter}, ConverterParameter=Admin}" Cursor="Hand" Margin="0,0,0,12">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding SelectRoleCommand}" CommandParameter="Admin" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="#E8F5E9" Margin="0,0,20,0">
                                    <materialDesign:PackIcon Kind="ChartLine" Width="28" Height="28" Foreground="#66BD76" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Admin / Manager" FontWeight="Bold" Foreground="#1B5E20" FontSize="16" />
                                    <TextBlock Text="Analytics &amp; Config" Foreground="#757575" FontSize="14" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="20" CornerRadius="12" Background="{Binding SelectedRole, Converter={StaticResource RoleSelectedBackgroundConverter}, ConverterParameter=Cashier}" BorderBrush="{Binding SelectedRole, Converter={StaticResource RoleSelectedBrushConverter}, ConverterParameter=Cashier}" BorderThickness="{Binding SelectedRole, Converter={StaticResource RoleSelectedThicknessConverter}, ConverterParameter=Cashier}" Cursor="Hand" Margin="0,0,0,12">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding SelectRoleCommand}" CommandParameter="Cashier" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="#E8F5E9" Margin="0,0,20,0">
                                    <materialDesign:PackIcon Kind="CashRegister" Width="28" Height="28" Foreground="#66BD76" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Cashier / Order" FontWeight="Bold" Foreground="#1B5E20" FontSize="16" />
                                    <TextBlock Text="Orders &amp; Payments" Foreground="#757575" FontSize="14" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="20" CornerRadius="12" Background="{Binding SelectedRole, Converter={StaticResource RoleSelectedBackgroundConverter}, ConverterParameter=Kitchen}" BorderBrush="{Binding SelectedRole, Converter={StaticResource RoleSelectedBrushConverter}, ConverterParameter=Kitchen}" BorderThickness="{Binding SelectedRole, Converter={StaticResource RoleSelectedThicknessConverter}, ConverterParameter=Kitchen}" Cursor="Hand" Margin="0,0,0,0">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding SelectRoleCommand}" CommandParameter="Kitchen" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="#E8F5E9" Margin="0,0,20,0">
                                    <materialDesign:PackIcon Kind="SilverwareForkKnife" Width="28" Height="28" Foreground="#66BD76" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Kitchen Staff" FontWeight="Bold" Foreground="#1B5E20" FontSize="16" />
                                    <TextBlock Text="Food Prep &amp; Status" Foreground="#757575" FontSize="14" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" CornerRadius="24" Background="White" Padding="32" BorderBrush="#E1E8E3" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                    </Style>
                </Border.Style>

                <StackPanel>
                    <TextBlock Text="Sign in" FontSize="32" FontWeight="Bold" Foreground="#1B5E20" />
                    <TextBlock Text="Secure access for authorized personnel only." Foreground="#757575" FontSize="14" Margin="0,8,0,24" />

                    <TextBlock Text="Username" Foreground="#616161" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Foreground="Black"
                             Margin="0,0,0,18" Height="48" FontSize="16" Background="#F5F5F5" BorderThickness="0">
                    </TextBox>

                    <TextBlock Text="Password" Foreground="#616161" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Foreground="Black"
                             Margin="0,0,0,8" Height="48" FontSize="16" Background="#F5F5F5" BorderThickness="0">
                    </TextBox>

                    <TextBlock Text="Forgot password?" Foreground="#66BD76" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,24" Cursor="Hand" />

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Button Content="Log in →" Command="{Binding LoginCommand}"
                            Background="#66BD76" BorderBrush="#66BD76" Foreground="White"
                            Height="48" FontSize="16" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="8" />

                    <Border Background="#F1F8E9" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#66BD76" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="System monitored. Access is restricted to authorized users." FontSize="12" Foreground="#616161" VerticalAlignment="Center" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer with Developer Credits -->
        <TextBlock Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16" FontSize="12">
            <Run Text="© 2026 KHAON POS • Developed by " Foreground="#757575"/>
            <Hyperlink NavigateUri="https://github.com/adibuljabir/" RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="Adibul Jabir" Foreground="#66BD76" FontWeight="SemiBold"/>
            </Hyperlink>
            <Run Text=" &amp; " Foreground="#757575"/>
            <Hyperlink NavigateUri="https://github.com/sezanX" RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="Sezan Mahood" Foreground="#66BD76" FontWeight="SemiBold"/>
            </Hyperlink>
        </TextBlock>
    </Grid>
</UserControl>
