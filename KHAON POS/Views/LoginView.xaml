<UserControl x:Class="RestaurantPOS.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:RestaurantPOS.ViewModels">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Select your role" FontSize="48" FontWeight="Bold" Foreground="#66BD76" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="Please choose your access level to enter the terminal. Secure authentication required after selection." 
                       FontSize="16" Foreground="#616161" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="500" TextAlignment="Center" Margin="0,0,0,48"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Admin Card -->
                <materialDesign:Card Width="240" Height="280" Margin="16" UniformCornerRadius="8" Cursor="Hand"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding SelectRoleCommand}" CommandParameter="Admin"/>
                    </materialDesign:Card.InputBindings>
                    <StackPanel VerticalAlignment="Center" Margin="24">
                        <Ellipse Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#66BD76" Opacity="1.0"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <materialDesign:PackIcon Kind="ChartLine" Width="40" Height="40" Foreground="White" HorizontalAlignment="Center" Margin="0,-80,0,40" />
                        <TextBlock Text="Admin / Manager" FontSize="18" FontWeight="Bold" Foreground="#66BD76" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Full system access. Manage staff, inventory, view detailed analytics, and configure terminal settings." 
                                   TextWrapping="Wrap" TextAlignment="Center" Foreground="#757575" FontSize="13"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Kitchen Staff Card -->
                <materialDesign:Card Width="240" Height="280" Margin="16" UniformCornerRadius="8" Cursor="Hand"
                                     materialDesign:ElevationAssist.Elevation="Dp2"
                                     BorderBrush="#66BD76" BorderThickness="2" Background="White">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding SelectRoleCommand}" CommandParameter="Kitchen"/>
                    </materialDesign:Card.InputBindings>
                    <StackPanel VerticalAlignment="Center" Margin="24">
                        <Ellipse Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#66BD76" Opacity="1.0"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <materialDesign:PackIcon Kind="SilverwareForkKnife" Width="40" Height="40" Foreground="White" HorizontalAlignment="Center" Margin="0,-80,0,40" />
                        <TextBlock Text="Kitchen Staff" FontSize="18" FontWeight="Bold" Foreground="#66BD76" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Back-of-house operations. Track incoming orders, manage cook times, &amp; update inventory status real-time." 
                                   TextWrapping="Wrap" TextAlignment="Center" Foreground="#757575" FontSize="13"/>
                    </StackPanel>
                </materialDesign:Card>
                
                <!-- Cashier Card -->
                <materialDesign:Card Width="240" Height="280" Margin="16" UniformCornerRadius="8" Cursor="Hand"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <materialDesign:Card.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding SelectRoleCommand}" CommandParameter="Cashier"/>
                    </materialDesign:Card.InputBindings>
                    <StackPanel VerticalAlignment="Center" Margin="24">
                        <Ellipse Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#66BD76" Opacity="1.0"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <materialDesign:PackIcon Kind="CashRegister" Width="40" Height="40" Foreground="White" HorizontalAlignment="Center" Margin="0,-80,0,40" />
                        <TextBlock Text="Cashier / Order" FontSize="18" FontWeight="Bold" Foreground="#66BD76" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Front-of-house operations. Process orders, handle payments, manage table bookings, and print receipts." 
                                   TextWrapping="Wrap" TextAlignment="Center" Foreground="#757575" FontSize="13"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
            
            <TextBlock Text="Developed By: Sezan Mahmood, UI/UX By: Adibul Jabir" Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,64,0,0"/>
        </StackPanel>

        <!-- Login Panel (Overlay) -->
        <materialDesign:Card Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Center" Width="400" Margin="32" UniformCornerRadius="16" materialDesign:ElevationAssist.Elevation="Dp8" Background="White">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRoleSelected}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>
            
            <StackPanel Margin="32">
                <Button Style="{StaticResource MaterialDesignIconForegroundButton}" Command="{Binding BackCommand}" HorizontalAlignment="Left" Margin="-16,-16,0,16">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="#757575"/>
                </Button>
                
                <TextBlock Text="Login" FontSize="36" Foreground="#66BD76" Margin="0,0,0,8"/>
                <TextBlock Text="Secure access for authorized personnel only." Foreground="#757575" FontSize="14" Margin="0,0,0,32"/>

                <TextBlock Text="Username" Foreground="#616161" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         materialDesign:HintAssist.Hint="yourname@something.com"
                         materialDesign:HintAssist.Foreground="#66BD76"
                         Foreground="Black"
                         Margin="0,0,0,24" Height="48" FontSize="16" Background="#F5F5F5" BorderThickness="0">
                    <materialDesign:HintAssist.HintOpacity>
                        1.0
                    </materialDesign:HintAssist.HintOpacity>
                </TextBox>
                
                <TextBlock Text="Password" Foreground="#616161" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="............"
                         materialDesign:HintAssist.Foreground="#66BD76"
                         Foreground="Black"
                         Margin="0,0,0,8" Height="48" FontSize="16" Background="#F5F5F5" BorderThickness="0">
                    <materialDesign:HintAssist.HintOpacity>
                        1.0
                    </materialDesign:HintAssist.HintOpacity>
                </TextBox>
                
                <TextBlock Text="Forgot password?" Foreground="#66BD76" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,32" Cursor="Hand"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,16" 
                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Button Content="Log in →" Command="{Binding LoginCommand}" 
                        Background="#66BD76" BorderBrush="#66BD76" Foreground="White" 
                        Height="48" FontSize="16" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="8"/>
                        
                <Border Background="#F1F8E9" CornerRadius="4" Padding="16" Margin="0,32,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#66BD76" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="System monitored. Access is restricted to authorized users." FontSize="12" Foreground="#616161" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
