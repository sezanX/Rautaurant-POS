<Window x:Class="KHAONPOS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:KHAONPOS.Views"
        xmlns:viewmodels="clr-namespace:KHAONPOS.ViewModels"
        Title="KHAON POS" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Arial, Calibri, Segoe UI, sans-serif"
        Icon="/logo.png">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CashierViewModel}">
            <views:CashierView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:KitchenViewModel}">
            <views:KitchenView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AdminDashboardViewModel}">
            <views:AdminDashboardView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Global Header -->
        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Source="/logo.png" Width="32" Height="32" Stretch="Uniform" Margin="0,0,8,0" />
                    <TextBlock Text="KHAON POS" FontSize="20" FontWeight="Bold" Foreground="#66BD76" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                   
                    <TextBlock Text="{Binding CurrentTime, StringFormat={}{0:h:mm:ss tt}}" FontWeight="Bold" Foreground="#212121" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding CurrentDate, StringFormat={}{0:MMM dd, yyyy}}"  Foreground="#757575" VerticalAlignment="Center" Margin="0,0,8,0" />
                   
                
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Support" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#757575" Height="32" Padding="8,0" Margin="0,0,24,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="HelpCircleOutline" Width="20" Height="20" Foreground="#757575" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="Support" Foreground="#757575" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Logout" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#E53935" Height="32" Padding="8,0" Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Logout" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
